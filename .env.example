# ============================================================
# VTV Assessment Platform — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Database (Neon Serverless PostgreSQL) ---
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- Base URL (auto-set for local dev, set for staging) ---
# Leave unset for production (defaults to https://assessment.valuetovictory.com)
# For staging: set to your Vercel preview URL
# For local dev: auto-set to http://localhost:3000
# BASE_URL=https://assessment.valuetovictory.com

# --- Authentication ---
JWT_SECRET=your-jwt-secret-here
ADMIN_API_KEY=your-admin-api-key-here

# --- Email (Gmail SMTP) ---
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_or_sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- AI Provider ---
# 'cloud' = Vercel AI Gateway with Claude (default, costs tokens)
# 'local' = Ollama running on your machine (free, requires local setup)
AI_PROVIDER=cloud

# Cloud AI (when AI_PROVIDER=cloud)
AI_GATEWAY_API_KEY=your-vercel-ai-gateway-key
CLOUD_AI_MODEL=anthropic/claude-sonnet-4.5

# Local AI (when AI_PROVIDER=local)
# Install Ollama: https://ollama.ai
# Then: ollama pull llama3.1:8b
OLLAMA_HOST=http://localhost:11434
LOCAL_MODEL_COACHING=llama3.1:8b
LOCAL_MODEL_SUMMARY=llama3.1:8b
LOCAL_MODEL_EMAIL=llama3.1:8b
LOCAL_MODEL_CONTENT=llama3.1:8b
LOCAL_MODEL_DEVOTIONAL=llama3.1:8b

# --- Optional: HubSpot CRM ---
# HUBSPOT_API_KEY=your-hubspot-key

# --- Optional: Email API ---
# SEND_EMAIL_API_KEY=your-send-email-key
